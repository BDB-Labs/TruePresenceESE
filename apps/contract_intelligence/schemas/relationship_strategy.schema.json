{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RelationshipStrategy",
  "type": "object",
  "required": ["negotiation_posture", "sensitive_issues", "leverage_points", "confidence"],
  "properties": {
    "negotiation_posture": {"type": "string"},
    "sensitive_issues": {
      "type": "array",
      "items": {"type": "string"}
    },
    "leverage_points": {
      "type": "array",
      "items": {"type": "string"}
    },
    "confidence": {"type": "number", "minimum": 0.0, "maximum": 1.0}
  }
}
