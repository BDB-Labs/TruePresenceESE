{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DecisionSummary",
  "type": "object",
  "required": [
    "project_id",
    "recommendation",
    "overall_risk",
    "confidence",
    "top_reasons",
    "must_fix_before_bid",
    "human_review_required"
  ],
  "properties": {
    "project_id": {"type": "string"},
    "recommendation": {"type": "string", "enum": ["go", "go_with_conditions", "no_go"]},
    "overall_risk": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
    "confidence": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "top_reasons": {
      "type": "array",
      "items": {"type": "string"}
    },
    "must_fix_before_bid": {
      "type": "array",
      "items": {"type": "string"}
    },
    "human_review_required": {"type": "boolean"}
  }
}
