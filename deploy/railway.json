{
  "$schema": "https://railway.app/schema.json",
  "name": "TruePresence-Telegram",
  "plugins": [],
  "environments": {
    "production": {
      "variables": {
        "PORT": "8000"
      }
    }
  },
  "services": {
    "truepresence": {
      "build": {
        "context": ".",
        "dockerfile": "deploy/Dockerfile"
      },
      "healthcheck": {
        "command": "curl -f http://localhost:${PORT:-8000}/health || exit 1",
        "interval": 30,
        "timeout": 10,
        "retries": 3,
        "startPeriod": 60
      },
      "port": {
        "port": 8000,
        "proxy": false
      },
      "variables": [
        {
          "key": "TELEGRAM_BOT_TOKEN",
          "generated": false,
          "required": true
        },
        {
          "key": "PORT",
          "value": "8000"
        }
      ]
    }
  }
}